# =============================================================================
# Denpyo Toroku Service - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# The .env file is loaded automatically by python-dotenv at application startup.
# Values set in actual environment variables take precedence over .env file.
# =============================================================================

# -----------------------------------------------------------------------------
# OCI Configuration (Required)
# -----------------------------------------------------------------------------
OCI_CONFIG_PATH=~/.oci/config
OCI_CONFIG_PROFILE=DEFAULT
OCI_CONFIG_COMPARTMENT=ocid1.compartment.oc1..xxxxx
OCI_SERVICE_ENDPOINT=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com
OCI_REGION=ap-osaka-1

# -----------------------------------------------------------------------------
# Classifier / Model
# -----------------------------------------------------------------------------
LLM_MODEL_ID=google.gemini-2.5-pro
EMBEDDING_MODEL_ID=cohere.embed-v4.0
# MODEL_PATH=denpyo_toroku/models/intent_model_production.pkl
# MODEL_DIR=denpyo_toroku/models
ENABLE_CACHE=true
CACHE_SIZE=10000
BATCH_SIZE=96

# -----------------------------------------------------------------------------
# Service
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
WEBAPP_PORT=5000
# DENPYO_TOROKU_DEBUG_MODE=false

# -----------------------------------------------------------------------------
# Gunicorn
# -----------------------------------------------------------------------------
GUNICORN_BIND=0.0.0.0:8080
# GUNICORN_DAEMON=false

# -----------------------------------------------------------------------------
# Database (optional - leave empty if not used)
# -----------------------------------------------------------------------------
# Oracle Database Configuration (semantic-doc-search compatible)
ORACLE_CLIENT_LIB_DIR=/u01/aipoc/instantclient_23_26
# TNS_ADMIN will be automatically set to ORACLE_CLIENT_LIB_DIR/network/admin
# Wallet files should be placed in ORACLE_CLIENT_LIB_DIR/network/admin
ORACLE_26AI_CONNECTION_STRING=admin/password@dsn
ADB_OCID=ocid1.autonomousdatabase.oc1..

# -----------------------------------------------------------------------------
# Security (optional)
# -----------------------------------------------------------------------------
# HOSTNAME=
# LOAD_BALANCER_ALIAS=
